# -*- mode: snippet -*-
# name: shell.nix — generic development shell
# key: shellnix
# --
{ pkgs ? import <nixpkgs> {} }:

pkgs.mkShell {
  name = "${1:dev-shell}";

  buildInputs = with pkgs; [
    ${2:# packages — e.g. git nodejs python3}
    $0
  ];

  shellHook = ''
    ${3:echo "Entered $name"}
  '';
}
